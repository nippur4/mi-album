# Variables expuestas al cliente (deben tener prefijo EXPO_PUBLIC_).
# Copiar a .env y completar con los valores del proyecto Supabase.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Base URL pública del bucket R2. Para r2.dev: https://pub-xxxxxxxx.r2.dev
# Para dominio custom: https://cdn.tuapp.com (sin slash al final).
EXPO_PUBLIC_R2_PUBLIC_BASE_URL=
