{
  "expo": {
    "name": "Mi Álbum de Figuritas",
    "slug": "mi-album-figuritas",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mialbum",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.mialbum.figuritas",
      "supportsTablet": false
    },
    "android": {
      "package": "com.mialbum.figuritas",
      "adaptiveIcon": {
        "backgroundColor": "#FBF3E2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "Mi Álbum de Figuritas",
      "shortName": "Mi Álbum",
      "description": "Creá y completá álbumes digitales de figuritas. Intercambiá con amigos.",
      "lang": "es",
      "themeColor": "#D23A2E",
      "backgroundColor": "#FBF3E2",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF3E2",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Necesitamos la cámara para escanear el QR de sobres del owner."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#D23A2E",
          "defaultChannel": "default"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6752256c-6f6f-4dda-8d28-4aecc63564aa"
      }
    }
  }
}
